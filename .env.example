# PostgreSQL
POSTGRES_DB=prompt_generator
POSTGRES_USER=prompt_user
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://prompt_user:change-me@localhost:5432/prompt_generator

# Backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
AUTO_CREATE_TABLES=true

# AI provider: "ollama" works locally without an API key; "openai" remains optional.
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:4b-instruct
OLLAMA_TIMEOUT_SECONDS=420
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT_SECONDS=45
